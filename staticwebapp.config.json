{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/js/*.js", "/api/*"]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "ALLOWALL",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".js": "text/javascript"
  }
}
